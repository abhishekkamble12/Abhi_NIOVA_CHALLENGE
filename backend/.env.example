# =============================================================================
# AI Media OS - HiveMind Configuration — Amazon Nova Edition
# =============================================================================
# Copy this file to .env and fill in your actual values
# =============================================================================

# Environment Configuration
# Options: development, staging, production
ENVIRONMENT=development
DEBUG=True
PROJECT_NAME=AI Media OS - HiveMind
API_V1_PREFIX=/api/v1
LOG_LEVEL=info

# Database Configuration
# Development: SQLite
DATABASE_URL=sqlite:///./hivemind.db
# Production: PostgreSQL with pgvector
# DATABASE_URL=postgresql://user:password@localhost:5432/hivemind

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# AI Services — Amazon Nova via Bedrock (replaces OpenAI and SentenceTransformers)
# No API key needed — uses AWS IAM credentials
NEWS_API_KEY=your-newsapi-key-here

# Vector Database Configuration — Nova Multimodal Embeddings (1024-dim)
VECTOR_DIMENSION=1024
EMBEDDING_MODEL=amazon.nova-2-multimodal-embeddings-v1:0

# Amazon Nova Model IDs
NOVA_TEXT_MODEL=amazon.nova-2-lite-v1:0
NOVA_SONIC_MODEL=amazon.nova-2-sonic-v1:0
NOVA_EMBEDDING_MODEL=amazon.nova-2-multimodal-embeddings-v1:0
NOVA_EMBEDDING_DIMENSION=1024

# Storage Configuration
UPLOAD_DIR=uploads

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=hivemind-media-storage

# CORS Origins (comma-separated for production)
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
