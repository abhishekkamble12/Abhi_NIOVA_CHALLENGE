# =============================================================================
# AI Media OS - HiveMind Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# =============================================================================

# Environment Configuration
# Options: development, staging, production
ENVIRONMENT=development
DEBUG=True
PROJECT_NAME=AI Media OS - HiveMind
API_V1_PREFIX=/api/v1
LOG_LEVEL=info

# Database Configuration
# Development: SQLite
DATABASE_URL=sqlite:///./hivemind.db
# Production: PostgreSQL with pgvector
# DATABASE_URL=postgresql://user:password@localhost:5432/hivemind

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# AI Service API Keys
# OpenAI for content generation and embeddings
OPENAI_API_KEY=sk-your-openai-api-key-here
# NewsAPI for news feed curation
NEWS_API_KEY=your-newsapi-key-here

# Vector Database Configuration
# Embedding dimension (384 for all-MiniLM-L6-v2)
VECTOR_DIMENSION=384
# Sentence transformer model for embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Storage Configuration
# Local upload directory
UPLOAD_DIR=uploads

# AWS Configuration (Optional - for production S3 storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=hivemind-media-storage

# CORS Origins (comma-separated for production)
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
