# ============================================
# AWS REGION
# ============================================

AWS_REGION=ap-south-1

# ============================================
# AURORA POSTGRESQL
# ============================================

DB_HOST=stack1-hiveminddb-84glvjiaphnd.cluster-cl4cayemmxtl.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=hiveminddb

# ============================================
# ELASTICACHE REDIS
# ============================================

REDIS_HOST=your-redis-cluster.xxxxx.0001.aps1.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_DB=0

# ============================================
# S3
# ============================================

S3_BUCKET=hivemind-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================
# BEDROCK
# ============================================

BEDROCK_MODEL_EMBEDDING=amazon.titan-embed-text-v2:0
BEDROCK_MODEL_TEXT=anthropic.claude-3-sonnet-20240229-v1:0

# ============================================
# EVENTBRIDGE
# ============================================

EVENT_BUS_NAME=default

# ============================================
# NEWS API (for real news feed)
# ============================================

NEWS_API_KEY=your_newsapi_key_here

# ============================================
# APPLICATION
# ============================================

ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
CACHE_TTL_EMBEDDING=86400
CACHE_TTL_FEED=300
