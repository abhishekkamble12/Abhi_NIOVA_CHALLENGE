# ============================================
# AWS REGION
# ============================================

AWS_REGION=ap-south-1

# ============================================
# AURORA POSTGRESQL
# ============================================

DB_HOST=stack1-hiveminddb-84glvjiaphnd.cluster-cl4cayemmxtl.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=hiveminddb

# ============================================
# ELASTICACHE REDIS
# ============================================

REDIS_HOST=your-redis-cluster.xxxxx.0001.aps1.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_DB=0

# ============================================
# S3
# ============================================

S3_BUCKET=hivemind-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================
# BEDROCK — Amazon Nova Models
# ============================================

BEDROCK_MODEL_EMBEDDING=amazon.nova-2-multimodal-embeddings-v1:0
BEDROCK_MODEL_TEXT=amazon.nova-2-lite-v1:0

# Nova-specific overrides (used by shared services)
NOVA_TEXT_MODEL=amazon.nova-2-lite-v1:0
NOVA_SONIC_MODEL=amazon.nova-2-sonic-v1:0
NOVA_EMBEDDING_MODEL=amazon.nova-2-multimodal-embeddings-v1:0
NOVA_EMBEDDING_DIMENSION=1024

# ============================================
# EVENTBRIDGE
# ============================================

EVENT_BUS_NAME=default

# ============================================
# NEWS API (for real news feed)
# ============================================

NEWS_API_KEY=your_newsapi_key_here

# ============================================
# APPLICATION
# ============================================

ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
CACHE_TTL_EMBEDDING=86400
CACHE_TTL_FEED=300
